rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read their own role doc; only Firebase Console/Admin can write
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // Journal: private per-user only
    match /journal/{entryId} {
      allow read, update, delete: if request.auth != null &&
        resource.data.uid == request.auth.uid;
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.uid;
    }

    // Scripts: same pattern as journal
    match /scripts/{scriptId} {
      allow read: if request.auth != null && (
        resource.data.uid == request.auth.uid ||
        resource.data.isPublic == true
      );
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.uid;
      allow update, delete: if request.auth != null &&
        resource.data.uid == request.auth.uid;
    }

    // Folders: own always accessible; public folders readable by any signed-in user
    match /folders/{folderId} {
      allow read: if request.auth != null && (
        resource.data.uid == request.auth.uid ||
        resource.data.isPublic == true
      );
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.uid;
      allow update, delete: if request.auth != null &&
        resource.data.uid == request.auth.uid;

      match /files/{fileId} {
        allow read: if request.auth != null && (
          get(/databases/$(database)/documents/folders/$(folderId)).data.uid == request.auth.uid ||
          get(/databases/$(database)/documents/folders/$(folderId)).data.isPublic == true
        );
        allow write: if request.auth != null &&
          get(/databases/$(database)/documents/folders/$(folderId)).data.uid == request.auth.uid;
      }
    }

  }
}
